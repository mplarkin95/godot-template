; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="New Game Project"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/icon.svg"

[autoload]

EventBus="*res://src/Autoload/EventBus/EventBus.gd"
AudioManager="*res://src/Autoload/audio/audio_manager.tscn"
SceneTransitionManager="*res://src/Autoload/scenes/scene_transition_manager.tscn"
GlobalEffects="*res://src/Autoload/effects/global_effects.tscn"
Settings="*res://src/Autoload/settings/settings.gd"
UIManager="*res://src/Autoload/UIManager/ui_manager.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
